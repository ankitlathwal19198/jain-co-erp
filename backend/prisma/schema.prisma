// Prisma schema for Jain & Co ERP
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  admin
  user
}

model User {
  id               String   @id @default(uuid())
  email            String   @unique
  password         String
  empId            String?  @unique
  name             String?
  contactNo        String?
  designation      String?
  workState        String?
  workLocation     String?
  reportingManager String?
  reportingNo      String?
  leaveApproval    String?
  leaveAppNo       String?
  role             Role     @default(user)
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@map("users")
}
